{
  "name": "rsvp-jstr-sh",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "pnpm run build && vite preview",
    "test": "vitest run",
    "auth:generate": "pnpx @better-auth/cli generate --output src/db/schema/auth.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply rsvp-db-local --local",
    "db:migrate:staging": "wrangler d1 migrations apply rsvp-db-staging --remote -e staging",
    "db:migrate:production": "wrangler d1 migrations apply rsvp-db --remote -e production",
    "db:studio:local": "drizzle-kit studio --config drizzle.local.config.ts",
    "deploy:staging": "pnpm run build:staging && wrangler deploy",
    "deploy:production": "pnpm run build:production && wrangler deploy",
    "cf-typegen": "wrangler types",
    "format": "prettier --write .",
    "images:og": "bash scripts/generate-wada-og.sh"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.37.0",
    "@headlessui/react": "^2.2.10",
    "@marsidev/react-turnstile": "^1.5.2",
    "@react-email/render": "^2.0.8",
    "@react-spring/web": "^10.0.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.7.11",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/router-plugin": "^1.167.35",
    "@use-gesture/react": "^10.3.1",
    "better-auth": "^1.6.11",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.91.0"
  }
}
