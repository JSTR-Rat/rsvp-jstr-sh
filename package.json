{
  "name": "rsvp-jstr-sh",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "pnpm run build && vite preview",
    "test": "vitest run",
    "auth:generate": "pnpx @better-auth/cli generate --output src/db/schema/auth.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply rsvp-db-local --local",
    "db:migrate:staging": "wrangler d1 migrations apply rsvp-db-staging --remote -e staging",
    "db:migrate:production": "wrangler d1 migrations apply rsvp-db --remote -e production",
    "db:studio:local": "drizzle-kit studio --config drizzle.local.config.ts",
    "deploy:staging": "pnpm run build:staging && wrangler deploy",
    "deploy:production": "pnpm run build:production && wrangler deploy",
    "cf-typegen": "wrangler types",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.13.8",
    "@headlessui/react": "^2.2.10",
    "@marsidev/react-turnstile": "^1.5.0",
    "@react-spring/web": "^10.0.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@use-gesture/react": "^10.3.1",
    "better-auth": "^1.6.5",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.83.0"
  }
}
